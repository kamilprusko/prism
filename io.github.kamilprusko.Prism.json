{
  "app-id": "io.github.kamilprusko.Prism",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "prism",
  "finish-args": [
    "--device=dri",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--share=ipc"
  ],
  "modules": [
    {
      "name": "vtk",
      "buildsystem": "cmake-ninja",
      "builddir": true,
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
        "-DVTK_BUILD_TESTING=OFF",
        "-DVTK_BUILD_EXAMPLES=OFF",
        "-DVTK_ENABLE_LOGGING=OFF",
        "-DVTK_ENABLE_REMOTE_MODULES=OFF",
        "-DVTK_WRAP_PYTHON=OFF",
        "-DVTK_WRAP_JAVA=OFF",
        "-DVTK_OPENGL_HAS_EGL=ON",
        "-DVTK_USE_X=OFF",
        "-DVTK_USE_WAYLAND_OPENGL=ON",
        "-DVTK_DEFAULT_RENDER_WINDOW_OFFSCREEN=OFF",
        "-DVTK_BUILD_ALL_MODULES=OFF",
        "-DVTK_ENABLE_KITS=ON",
        "-DVTK_GROUP_ENABLE_Rendering=WANT",
        "-DVTK_GROUP_ENABLE_StandAlone=WANT",
        "-DVTK_MODULE_ENABLE_VTK_ViewsContext2D=DONT_WANT",
        "-DVTK_MODULE_ENABLE_VTK_TestingCore=DONT_WANT"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://www.vtk.org/files/release/9.5/VTK-9.5.2.tar.gz",
          "sha256": "cee64b98d270ff7302daf1ef13458dff5d5ac1ecb45d47723835f7f7d562c989"
        }
      ]
    },
    {
      "name": "prism",
      "buildsystem": "meson",
      "config-opts": [
        "--libdir=lib",
        "-Dvtk_kits=true"
      ],
      "build-options": {
        "env": {
          "CMAKE_PREFIX_PATH": "/app"
        }
      },
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
