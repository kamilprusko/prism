{
  "app-id": "io.github.kamilprusko.Prism",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "prism",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "vtk",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
        "-DBUILD_SHARED_LIBS=ON",
        "-DVTK_BUILD_TESTING=OFF",
        "-DVTK_BUILD_EXAMPLES=OFF",
        "-DVTK_ENABLE_LOGGING=ON",
        "-DVTK_ENABLE_REMOTE_MODULES=OFF",
        "-DVTK_WRAP_PYTHON=OFF",
        "-DVTK_OPENGL_HAS_EGL=ON",
        "-DVTK_USE_X=ON",
        "-DCMAKE_DISABLE_FIND_PACKAGE_Qt6=ON",
        "-DCMAKE_DISABLE_FIND_PACKAGE_Qt5=ON",
        "-DCMAKE_DISABLE_FIND_PACKAGE_MPI=ON"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://www.vtk.org/files/release/9.4/vtk-9.4.2.tar.gz",
          "sha256": "80c3fe2ae1062abf56456f52518bd670f9ec3917b7f85e152b347ac6b6faf880"
        }
      ]
    },
    {
      "name": "prism",
      "buildsystem": "meson",
      "config-opts": [
        "--libdir=lib"
      ],
      "build-options": {
        "env": {
          "CMAKE_PREFIX_PATH": "/app"
        }
      },
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
