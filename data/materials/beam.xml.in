<?xml version="1.0" encoding="UTF-8"?>
<!--
  Material manifest (reference). Runtime applies Phong via beam_apply_material()
  in src/materials.cpp; cell scalar colors from the ray tracer use the default mapper.
-->
<Material>
	<Property>
		<Member name="Opacity" value="0.99" />
		<Member name="FrontfaceCulling" value="0" />
		<Member name="BackfaceCulling" value="0" />
		<Member name="Ambient" value="0.35" />
		<Member name="AmbientColor" number_of_elements="3" type="Float" value="0.85 0.92 1.0" />
		<Member name="Diffuse" value="0.65" />
		<Member name="DiffuseColor" number_of_elements="3" type="Float" value="0.55 0.78 1.0" />
		<Member name="Specular" value="0.35" />
		<Member name="SpecularColor" number_of_elements="3" type="Float" value="1.0 1.0 1.0" />
		<Member name="SpecularPower" value="32.0" />
	</Property>
</Material>
